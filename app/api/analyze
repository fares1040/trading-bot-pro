import { NextResponse } from 'next/server';
import { GoogleGenerativeAI } from "@google/generative-ai";

export async function POST(req: Request) {
  try {
    const { symbol } = await req.json();
    const apiKey = process.env.GEMINI_API_KEY;

    if (!apiKey) {
      return NextResponse.json({ analysis: "خطأ برمجي: المفتاح غير موجود في الخادم" });
    }

    const genAI = new GoogleGenerativeAI(apiKey);
    // جرب استخدام 'gemini-1.5-flash' بدلاً من 'gemini-pro' لأنه أحدث وأسرع في الاستجابة
    const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });

    const result = await model.generateContent(`حلل السهم ${symbol} فنياً.`);
    const response = await result.response;
    return NextResponse.json({ analysis: response.text() });
    
  } catch (error: any) {
    // هذا السطر سيكتب الخطأ الحقيقي في Vercel Logs
    console.error("DEBUG_ERROR:", error.message);
    return NextResponse.json({ analysis: "خطأ تقني: " + error.message });
  }
}
