import { NextResponse } from 'next/server';
import { GoogleGenerativeAI } from "@google/generative-ai";

export async function POST(req: Request) {
  try {
    const { symbol } = await req.json();
    // تأكد من وجود process.env.GEMINI_API_KEY
    const apiKey = process.env.GEMINI_API_KEY;
    if (!apiKey) {
      return NextResponse.json({ analysis: "مفتاح API غير موجود في إعدادات الخادم." });
    }
    
    const genAI = new GoogleGenerativeAI(apiKey);
    const model = genAI.getGenerativeModel({ model: "gemini-pro" });

    const prompt = `حلل السهم ${symbol} فنياً كمتداول محترف، ركز على احتمالية الانفجار السعري. كن مختصراً.`;
    const result = await model.generateContent(prompt);
    
    return NextResponse.json({ analysis: result.response.text() });
  } catch (error) {
    console.error("Gemini Error:", error);
    return NextResponse.json({ analysis: "حدث خطأ أثناء الاتصال بالذكاء الاصطناعي." });
  }
}
