import { NextResponse } from 'next/server';
import { GoogleGenerativeAI } from "@google/generative-ai";

export async function POST(req: Request) {
  const { symbol } = await req.json();
  const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);
  const model = genAI.getGenerativeModel({ model: "gemini-pro" });

  // هنا نطلب منه أرقاماً محددة
  const prompt = `حلل السهم ${symbol} فنياً.
  1. حدد نقطة المقاومة (Resistance) الحالية.
  2. حدد نقطة الكسر (Breakout) التي لو تجاوزها السهم سينفجر.
  3. هل هو في مرحلة تجميع؟ (نعم/لا).
  أجب باختصار شديد وبشكل منظم.`;
  
  const result = await model.generateContent(prompt);
  return NextResponse.json({ analysis: result.response.text() });
}
